plugins.infrastructure.fingerprint_os
plugins.infrastructure.server_header
plugins.infrastructure.allowed_methods
plugins.infrastructure.favicon_identification

# ============================================================
# AUDIT PLUGINS - Vulnerability Detection
# ============================================================

# Classic Vulnerabilities (Already Present)
plugins.audit.sqli                    # SQL Injection
plugins.audit.xss                     # Cross-Site Scripting
plugins.audit.xxe                     # XML External Entity
plugins.audit.lfi                     # Local File Inclusion
plugins.audit.rfi                     # Remote File Inclusion
plugins.audit.os_commanding           # OS Command Injection
plugins.audit.csrf                    # Cross-Site Request Forgery
plugins.audit.cors_origin             # CORS Misconfiguration
plugins.audit.dav                     # WebDAV vulnerabilities
plugins.audit.websockets

# Modern Vulnerabilities (NEW!)
plugins.audit.ssti                    # Server-Side Template Injection
plugins.audit.jwt                     # JWT Security Testing
plugins.audit.graphql                 # GraphQL Security
plugins.audit.nosql                   # NoSQL Injection
# plugins.audit.idor                   # Insecure Direct Object Reference (when available)
# plugins.audit.ssrf                   # Server-Side Request Forgery (when available)

# Additional Audits
plugins.audit.generic
plugins.audit.redos                    # Regular Expression DoS
plugins.audit.response_splitting
plugins.audit.file_upload
plugins.audit.shell_shock             # Shellshock
plugins.audit.ssl_certificate
plugins.audit.un_ssl                  # Untrusted SSL
plugins.audit.deserialization

