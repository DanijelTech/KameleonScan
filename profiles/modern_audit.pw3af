# Modern Web Security Audit Profile
# Comprehensive profile for modern web application security testing
# Includes all modern vulnerability checks

# ============================================================
# CRAWL PLUGINS - Discovery
# ============================================================

# Web Spider - Basic crawling
plugins.crawl.web_spider
plugins.crawl.web_spider.only_forward

# OpenAPI / GraphQL Discovery (NEW!)
plugins.crawl.open_api                 # OpenAPI 3.x / Swagger
plugins.crawl.robots_txt
plugins.crawl.sitemap_xml

# Content Discovery
plugins.crawl.dir_file_bruter
plugins.crawl.url_fuzzer
plugins.crawl.archive_dot_org

# Technology Fingerprinting
plugins.crawl.find_dvcs                # Git exposure
plugins.crawl.phpinfo                  # PHPInfo detection

# ============================================================
# INFRASTRUCTURE PLUGNS - Discovery
# ============================================================

# Cloud Security (NEW!)
